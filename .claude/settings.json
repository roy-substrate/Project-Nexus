{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$NEXUS_AGENCY_SESSION\" ] && exit 0; NEXUS_AGENCY_SESSION=1 claude -p \"/nexus-agency\" 2>/dev/null",
            "async": true,
            "statusMessage": "Nexus pipeline running..."
          }
        ]
      }
    ]
  }
}
